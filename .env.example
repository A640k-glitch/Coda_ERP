# Coda Environment Configuration
# Copy this file to .env and fill in your values

# Admin email address (used for admin panel access and notifications)
# CODA_ADMIN_EMAIL=admin@example.com

# CSRF secret — generate a random 32-character hex string
# You can generate one with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# CSRF_SECRET=your_random_32_hex_chars_here

# Node environment: development, production
# NODE_ENV=development

# Server port (default: 3100)
# PORT=3100

# CORS allowed origins (comma-separated, or leave blank to allow all)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# --- Integration API Keys (optional — leave blank for mock data in dev) ---

# QoreID API key for CAC verification
# QOREID_SECRET_KEY=

# Mono API key for bank statement sync
# MONO_SECRET_KEY=

# FIRS API key for tax filing
# FIRS_API_KEY=

# Termii API key for SMS notifications
# TERMII_API_KEY=

# SendGrid API key for email notifications
# SENDGRID_API_KEY=

# PFA API key for pension compliance
# PFA_API_KEY=

# --- Demo Seed Data (development only) ---
# When NODE_ENV=development and the database is empty, the app seeds
# demo accounts. Demo credentials:
#   Admin: demo@codaerp.ng / Admin@123
#   Owner: owner@afritrade.ng / Demo@123
